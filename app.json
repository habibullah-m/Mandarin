{
  "expo": {
    "name": "Mandarin",
    "slug": "Mandarin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mandarin",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.habibullahi.Mandarin",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs microphone access for pronunciation practice."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffcc",
        "foregroundImage": "./assets/images/android-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.habibullahi.Mandarin",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffcc"
        }
      ],
      "expo-secure-store",
      "expo-video",
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for pronunciation practice"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
